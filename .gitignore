# ============================================================
# Meridian — root .gitignore
# Covers client/, server/, and the repo root.
# ============================================================

# ── CRITICAL: secrets & credentials ──────────────────────────
.env
.env.local
.env.*.local
.env.production

# ── Dependencies ──────────────────────────────────────────────
node_modules/
client/node_modules/
server/node_modules/

# ── Build outputs ─────────────────────────────────────────────
dist/
build/
server/public/        # Vite production build (served by Express)
client/dist/

# ── TypeScript cache ──────────────────────────────────────────
*.tsbuildinfo

# ── Vite cache ────────────────────────────────────────────────
client/.vite/

# ── Logs ──────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS & editor artifacts ─────────────────────────────────────
.DS_Store
Thumbs.db
*.pem
.vscode/
.idea/
*.swp
*.swo
.claude
AGENTS.md
CLAUDE.md